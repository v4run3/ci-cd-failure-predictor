# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.env/

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Data files (keep structure, ignore contents)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Model artifacts
*.pkl
*.joblib
*.h5

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Distribution / packaging
dist/
build/
*.egg-info/

# Environment variables
.env

# Frontend build artifacts
frontend/node_modules/
frontend/dist/

# Model metadata backup files
*.pkl.bak
*.json.bak

# DVC local cache (data + models live in .dvc/cache, tracked via .dvc pointer files)
/.dvc/cache
/.dvc/tmp
